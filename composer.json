        "phpunit/php-invoker": "^4.0"

    },
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "openai-php/client": "^0.19.2",
        "symfony/http-client": "^8.0",
        "nyholm/psr7": "^1.8",
